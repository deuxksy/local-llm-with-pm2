[Unit]
Description=PM2 process manager
Documentation=https://pm2.keymetrics.io/
After=network.target

[Service]
Type=forking
Environment=PATH=/home/deck/.local/share/mise/installs/node/24/bin:/home/deck/.local/share/pnpm:/usr/bin
Environment=PM2_HOME=/home/deck/.pm2
ExecStart=/bin/bash -lc 'pm2 resurrect'
ExecReload=/bin/bash -lc 'pm2 reload all'
ExecStop=/bin/bash -lc 'pm2 kill'
PIDFile=/home/deck/.pm2/pm2.pid
Restart=on-failure

[Install]
WantedBy=default.target
